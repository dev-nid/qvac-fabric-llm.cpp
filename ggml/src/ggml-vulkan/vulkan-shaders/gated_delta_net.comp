#version 450

#extension GL_EXT_control_flow_attributes : require
#extension GL_KHR_shader_subgroup_basic : enable
#if USE_SUBGROUP_CLUSTERED
#extension GL_KHR_shader_subgroup_clustered : enable
#endif
#if USE_SUBGROUP_ADD
#extension GL_KHR_shader_subgroup_arithmetic : enable
#endif

// Caller guarantees valid spec constants: S_V % COLS_PER_WG == 0 and S_V % LANES_PER_COLUMN == 0,
// so no bounds checking is needed.
layout(constant_id = 0) const uint S_V = 128;
layout(constant_id = 1) const uint KDA = 0;
layout(constant_id = 2) const uint SUBGROUP_SIZE = 32;
layout(constant_id = 3) const uint LANES_PER_COLUMN = 32;

const uint COLS_PER_WG = SUBGROUP_SIZE / LANES_PER_COLUMN;
const uint ROWS_PER_LANE = S_V / LANES_PER_COLUMN;

layout(local_size_x_id = 2, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform Parameters {
    uint H;
    uint n_tokens;
    uint n_seqs;
    uint s_off;
    uint sq1, sq2, sq3;
    uint sv1, sv2, sv3;
    uint sb1, sb2, sb3;
    uint neq1, rq3;
    float scale;
#if WRITE_STATE_HISTORY
    // per-token state-history region offset inside dst, in floats. Only the
    // WITH_HISTORY variant of the pipeline reads this; the legacy chain
    // pipeline declares an identical struct without the field
    // so the byte layout doesn't shift.
    uint sh_off;
#endif
};

layout(binding = 0) readonly  buffer QBuf     { FLOAT_TYPE data_q[];     };
layout(binding = 1) readonly  buffer KBuf     { FLOAT_TYPE data_k[];     };
layout(binding = 2) readonly  buffer VBuf     { FLOAT_TYPE data_v[];     };
layout(binding = 3) readonly  buffer GBuf     { FLOAT_TYPE data_g[];     };
layout(binding = 4) readonly  buffer BetaBuf  { FLOAT_TYPE data_beta[];  };
layout(binding = 5) readonly  buffer StateBuf { FLOAT_TYPE data_state[]; };
layout(binding = 6)           buffer DstBuf   { FLOAT_TYPE data_dst[];   };
#if TREE_MODE
// DFlash tree-mode inputs. parent_ids carries [n_tokens, n_seqs] i32;
// for each token t in [1, n_tokens), parent_ids[t] is either:
//   - t - 1   : sequential continuation (no extra cost; keep s_shard).
//   - >= 0    : another token in this same verify; reload state from
//               the dst-embedded state_history region at that slot
//               (WRITE_PERSIST_INTER=0) or persist_inter (=1).
//   - -1      : "before the block" — reset state to data_state (curr_state)
//               from src[5]. The kernel TREE_MODE convention treats < 0 the
//               same as -1 (root sentinel).
//
// Two storage modes, picked at pipeline-compile time:
//
//   WRITE_PERSIST_INTER=0 (regular WITH_HISTORY tree pipeline):
//     - shader writes per-token state to dst's embedded state_history
//       region (same buffer as data_dst).
//     - parent-walk reload reads from data_dst.
//     - graph builder appends a ggml_cpy(state_history_view ->
//       persist_inter) after this dispatch.
//
//   WRITE_PERSIST_INTER=1 (CUDA-parity persist pipeline; F32 only):
//     - shader writes per-token state directly into persist_inter
//       (binding 8) and the embedded state_history region of dst is
//       left undefined.
//     - parent-walk reload reads from persist_inter.
//     - graph builder MUST NOT emit the follow-up ggml_cpy. Matches
//       lucebox's `ggml_gated_delta_net_tree_persist`.
//     - F16 persist storage is intentionally NOT compiled here: a prior
//       attempt to write F16 persist_inter triggered a cross-iter
//       same-thread read-after-write hazard on RADV/amdgpu even with
//       `coherent` + `memoryBarrierBuffer()`. F32 storage doesn't hit
//       that hazard on the drivers we've tested (NVIDIA + RADV).
layout(binding = 7) readonly  buffer ParentIds { int parent_ids[]; };
#if WRITE_PERSIST_INTER
#if PERSIST_TYPE_F16
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
layout(binding = 8)           buffer PersistBuf { float16_t data_persist[]; };
#else
layout(binding = 8)           buffer PersistBuf { float     data_persist[]; };
#endif
#endif
#endif

#if !USE_SUBGROUP_ADD && !USE_SUBGROUP_CLUSTERED
shared FLOAT_TYPE temp[SUBGROUP_SIZE];

// This does a reduction across groups of LANES_PER_COLUMN
FLOAT_TYPE reduce_add_shmem(FLOAT_TYPE partial) {
    const uint lane = gl_SubgroupInvocationID;
    temp[lane] = partial;
    barrier();
    [[unroll]] for (uint s = LANES_PER_COLUMN / 2u; s > 0; s >>= 1u) {
        FLOAT_TYPE other = temp[lane ^ s];
        barrier();
        temp[lane] += other;
        barrier();
    }
    const FLOAT_TYPE result = temp[lane];
    barrier();
    return result;
}
#endif

// clusterSize for subgroupClusteredAdd must be a compile-time constant; branch on spec constant
FLOAT_TYPE reduce_partial(FLOAT_TYPE partial) {
    switch (LANES_PER_COLUMN) {
        case 1u:
            return partial;
#if USE_SUBGROUP_CLUSTERED
        // Workaround for GLSL requiring a literal constant for the cluster size.
        // The branches should all fold away.
        case 2u:
            return subgroupClusteredAdd(partial, 2u);
        case 4u:
            return subgroupClusteredAdd(partial, 4u);
        case 8u:
            return subgroupClusteredAdd(partial, 8u);
        case 16u:
            return subgroupClusteredAdd(partial, 16u);
        case 32u:
            return subgroupClusteredAdd(partial, 32u);
        case 64u:
            return subgroupClusteredAdd(partial, 64u);
#endif
        default:
#if USE_SUBGROUP_ADD
            return subgroupAdd(partial);
#else
            return reduce_add_shmem(partial);
#endif
    }
}

void main() {
    const uint head_id = gl_WorkGroupID.x;
    const uint seq_id = gl_WorkGroupID.y;
    const uint lane = gl_SubgroupInvocationID % LANES_PER_COLUMN;
    const uint col = gl_WorkGroupID.z * COLS_PER_WG + (gl_SubgroupInvocationID / LANES_PER_COLUMN);

    const uint iq1 = head_id % neq1;
    const uint iq3 = seq_id / rq3;

    const uint state_size = S_V * S_V;
    const uint state_base = (seq_id * H + head_id) * state_size;

    FLOAT_TYPE s_shard[ROWS_PER_LANE];
    [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
        s_shard[r] = FLOAT_TYPE(data_state[state_base + col * S_V + r * LANES_PER_COLUMN + lane]);
    }

    uint attn_off = (seq_id * n_tokens * H + head_id) * S_V;

#if TREE_MODE
    // Per-seq parent slice for the branch-point reload below.
    const uint parent_seq_base = seq_id * n_tokens;
#endif

    for (uint t = 0; t < n_tokens; t++) {
#if TREE_MODE
        // Tree branch-point reload: always reads from dst's embedded
        // state_history region (F32). This is the same buffer the per-iter
        // store below writes into (when in the non-persist tree path) AND
        // the buffer we mirror to when WRITE_PERSIST_INTER is set — so the
        // in-dispatch R-A-W is always same-thread, same-SSBO, same-element
        // type (F32), guaranteed safe by the Vulkan memory model. The
        // persist mirror exists only to be consumed by the next iter's
        // ggml_gated_delta_net_state_select; it is never read inside this
        // dispatch, so F16 storage there is safe.
        if (t > 0) {
            const int parent_t = parent_ids[parent_seq_base + t];
            if (parent_t < 0) {
                [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
                    s_shard[r] = FLOAT_TYPE(data_state[state_base + col * S_V + r * LANES_PER_COLUMN + lane]);
                }
            } else if (uint(parent_t) != t - 1u) {
                const uint pbase = sh_off
                    + ((seq_id * n_tokens + uint(parent_t)) * H + head_id) * state_size
                    + col * S_V;
                [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
                    s_shard[r] = FLOAT_TYPE(data_dst[pbase + r * LANES_PER_COLUMN + lane]);
                }
            }
        }
#endif

        const uint q_off = iq3 * sq3 + t * sq2 + iq1 * sq1;
        const uint k_off = q_off;
        const uint v_off = seq_id * sv3 + t * sv2 + head_id * sv1;
        const uint gb_off = seq_id * sb3 + t * sb2 + head_id * sb1;
        const FLOAT_TYPE beta_val = FLOAT_TYPE(data_beta[gb_off]);

        FLOAT_TYPE k_reg[ROWS_PER_LANE];
        FLOAT_TYPE q_reg[ROWS_PER_LANE];
        [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
            const uint i = r * LANES_PER_COLUMN + lane;
            k_reg[r] = FLOAT_TYPE(data_k[k_off + i]);
            q_reg[r] = FLOAT_TYPE(data_q[q_off + i]);
        }

        FLOAT_TYPE g_exp[ROWS_PER_LANE];
        if (KDA == 0) {
            const FLOAT_TYPE g_val = exp(FLOAT_TYPE(data_g[gb_off]));
            [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
                g_exp[r] = g_val;
            }
        } else {
            const uint g_base = gb_off * S_V;
            [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
                const uint i = r * LANES_PER_COLUMN + lane;
                g_exp[r] = exp(FLOAT_TYPE(data_g[g_base + i]));
            }
        }

        const FLOAT_TYPE v_val = FLOAT_TYPE(data_v[v_off + col]);

        FLOAT_TYPE kv_shard = 0.0;
        [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
            kv_shard += g_exp[r] * s_shard[r] * k_reg[r];
        }
        FLOAT_TYPE kv_col = reduce_partial(kv_shard);

        FLOAT_TYPE delta_col = (v_val - kv_col) * beta_val;

        FLOAT_TYPE attn_partial = 0.0;
        [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
            s_shard[r] = g_exp[r] * s_shard[r] + k_reg[r] * delta_col;
            attn_partial += s_shard[r] * q_reg[r];
        }
        FLOAT_TYPE attn_col = reduce_partial(attn_partial);

        if (lane == 0) {
            data_dst[attn_off + col] = attn_col * scale;
        }

#if WRITE_STATE_HISTORY
        // Per-token state spill. Always write to dst's embedded F32 region;
        // when WRITE_PERSIST_INTER is also set, MIRROR the same shard into
        // persist_inter so the post-kernel ggml_cpy can be skipped by the
        // graph builder. The reload above reads from the f32 dst region
        // (safe same-SSBO R-A-W); persist_inter is written for the next
        // iter's state_select consumer only — it is not read in this
        // dispatch, so F16 storage on persist_inter is hazard-free.
        const uint sh_base = sh_off
            + ((seq_id * n_tokens + t) * H + head_id) * state_size
            + col * S_V;
        [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
            data_dst[sh_base + r * LANES_PER_COLUMN + lane] = s_shard[r];
        }
#if TREE_MODE && WRITE_PERSIST_INTER
        const uint p_base =
            ((seq_id * n_tokens + t) * H + head_id) * state_size
            + col * S_V;
        [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
#if PERSIST_TYPE_F16
            data_persist[p_base + r * LANES_PER_COLUMN + lane] = float16_t(s_shard[r]);
#else
            data_persist[p_base + r * LANES_PER_COLUMN + lane] = s_shard[r];
#endif
        }
#endif
#endif

        attn_off += S_V * H;
    }

    [[unroll]] for (uint r = 0; r < ROWS_PER_LANE; r++) {
        data_dst[s_off + state_base + col * S_V + r * LANES_PER_COLUMN + lane] = s_shard[r];
    }
}
