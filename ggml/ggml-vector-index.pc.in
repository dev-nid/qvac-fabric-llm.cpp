prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=@CMAKE_INSTALL_PREFIX@
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@

Name: ggml-vector-index
Description: Vector index library for ggml
Version: @GGML_VERSION@
Libs: -L${libdir} -lggml-vector-index
Libs.private: @GGML_VECTOR_INDEX_PC_LIBS_PRIVATE@
Cflags: -I${includedir}
